<Application x:Class="TorProxy.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis" />

        <!-- Palette (dark, calm) -->
        <SolidColorBrush x:Key="Bg"        Color="#1B1B1D" />
        <SolidColorBrush x:Key="Card"      Color="#232327" />
        <SolidColorBrush x:Key="CardBorder" Color="#33333A" />
        <SolidColorBrush x:Key="Text"      Color="#ECECEC" />
        <SolidColorBrush x:Key="Muted"     Color="#9A9AA2" />
        <SolidColorBrush x:Key="Accent"    Color="#2FA84F" />
        <SolidColorBrush x:Key="AccentHov" Color="#37BE5A" />
        <SolidColorBrush x:Key="Danger"    Color="#C0392B" />
        <SolidColorBrush x:Key="DangerHov" Color="#D0463A" />
        <SolidColorBrush x:Key="DotGrey"   Color="#6B6B72" />
        <SolidColorBrush x:Key="DotWork"   Color="#E0A22B" />
        <SolidColorBrush x:Key="DotReady"  Color="#2FA84F" />
        <SolidColorBrush x:Key="DotError"  Color="#C0392B" />

        <!-- Primary action button -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Height" Value="48" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="{StaticResource Accent}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Opacity" Value="0.92" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="b" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Small secondary button -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="{StaticResource CardBorder}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Opacity" Value="0.85" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="b" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ToolTip">
            <Setter Property="MaxWidth" Value="320" />
        </Style>
    </Application.Resources>
</Application>
